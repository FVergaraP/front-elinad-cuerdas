---
import { courses, WHATSAPP_BUSINESS_URL } from '@/data/courses';
import CourseCard from '@/components/ui/CourseCard.astro';
import imgKofi from '../../assets/images/kofi.png';
---

<section id="cursos" aria-labelledby="courses-heading" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Encabezado -->
    <div class="text-center mb-14">
      <span class="text-theme-accent font-semibold text-sm uppercase tracking-widest">
        Lo que ofrezco
      </span>
      <h2 id="courses-heading" class="section-title mt-2">
        Cursos & Talleres
      </h2>
      <p class="section-subtitle mx-auto mt-4">
        Elige el curso que más te interese y avanza a tu propio ritmo con un enfoque práctico y personalizado.
      </p>
    </div>

    <!-- Grid de cursos -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
      role="list"
      aria-label="Lista de cursos disponibles"
    >
      {courses.map((course) => (
        <div role="listitem" class="animate-slide-up h-full">
          <CourseCard course={course} />
        </div>
      ))}

      <!-- Tarjeta Ko-fi -->
      <div role="listitem" class="animate-slide-up h-full">
        <article class="card flex flex-col group h-full" aria-label="Apoya el proyecto musical de Elinad">
          <div class="flex flex-col flex-1 p-5 gap-3">
            <h3 class="text-xl font-display font-bold text-theme-text group-hover:text-theme-accent transition-colors">
              Apoya mi trabajo musical ❤️
            </h3>
            <p class="text-theme-muted text-sm leading-relaxed">
              ¿Te ha gustado o servido mi contenido? Puedes apoyarme en Ko-fi. Cada aporte me ayuda
              a seguir creando material educativo, nuevos proyectos musicales y recursos para la comunidad.
            </p>
            <div class="flex-1 flex items-center justify-center">
              <img
                src={imgKofi.src}
                alt="Elinad Bass en Ko-fi"
                width="200"
                height="200"
                class="w-20 h-20 rounded-full object-cover object-top ring-2 ring-theme-accent/30"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
          <div class="border-t border-theme-border p-5">
            <a
              href="https://ko-fi.com/elinadbass"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary w-full justify-center"
              aria-label="Apoyar a Elinad en Ko-fi"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                   fill="currentColor" aria-hidden="true">
                <path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.023c-.076-.057-.108-.09-.108-.09-.443-.441-3.368-3.049-4.034-3.954-.709-.965-1.041-2.7-.091-3.71.951-1.01 3.005-1.086 4.363.407 0 0 1.565-1.782 3.468-.963 1.904.82 1.832 2.692.723 4.311zm6.173.478c-.928.116-1.682.028-1.682.028V7.284h1.77s1.971.551 1.971 2.638c0 1.913-.985 2.667-2.059 3.015z"/>
              </svg>
              ☕ Invítame un café
            </a>
          </div>
        </article>
      </div>
    </div>

    <!-- CTA final -->
    <div class="mt-14 text-center">
      <p class="text-theme-muted mb-4 text-sm">
        ¿No encontraste lo que buscabas? Cuéntame qué necesitas y armamos algo a tu medida.
      </p>
      <a
        href={WHATSAPP_BUSINESS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary inline-flex"
        aria-label="Contactar por WhatsApp para clases personalizadas"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        Consultar por clase personalizada
      </a>
    </div>
  </div>
</section>

---
import type { Course } from '@/data/courses';
import { buildWhatsappUrl } from '@/data/courses';

interface Props {
  course: Course;
}

const { course } = Astro.props;

const whatsappUrl = buildWhatsappUrl(course.whatsappMessage);

const priceFormatted = new Intl.NumberFormat('es-CL', {
  style: 'currency',
  currency: course.currency,
  maximumFractionDigits: 0,
}).format(course.price);

const modalityColors: Record<string, string> = {
  Presencial: 'text-green-400 bg-green-400/10',
  Online:     'text-blue-400  bg-blue-400/10',
  Híbrido:    'text-yellow-400 bg-yellow-400/10',
};

const levelColors: Record<string, string> = {
  'Principiante':     'text-emerald-400  bg-emerald-400/10',
  'Intermedio':       'text-amber-400    bg-amber-400/10',
  'Avanzado':         'text-red-400      bg-red-400/10',
  'Todos los niveles':'text-theme-accent bg-theme-accent/10',
};
---

<article class="card flex flex-col group" aria-label={`Curso: ${course.title}`}>
  <!-- Badge de nivel + modalidad -->
  <div class="flex items-center gap-2 p-4 pb-0 flex-wrap">
    <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${levelColors[course.level] ?? ''}`}>
      {course.level}
    </span>
    <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${modalityColors[course.modality] ?? ''}`}>
      {course.modality}
    </span>
    {course.featured && (
      <span class="ml-auto text-xs font-bold px-2.5 py-1 rounded-full bg-theme-accent/20 text-theme-accent">
        Destacado ✦
      </span>
    )}
  </div>

  <!-- Contenido -->
  <div class="flex flex-col flex-1 p-5 gap-3">
    <h3 class="text-xl font-display font-bold text-theme-text group-hover:text-theme-accent transition-colors">
      {course.title}
    </h3>

    <p class="text-theme-muted text-sm leading-relaxed flex-1">
      {course.shortDescription}
    </p>

    <!-- Detalles -->
    <ul class="grid grid-cols-2 gap-x-4 gap-y-1.5 text-xs text-theme-muted mt-1" aria-label="Detalles del curso">
      <li class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
             stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        {course.duration}
      </li>
      <li class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
             stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        {course.sessions}
      </li>
    </ul>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5" aria-label="Etiquetas">
      {course.tags.map((tag) => (
        <span class="text-xs px-2 py-0.5 rounded-md bg-theme-border/50 text-theme-muted">
          #{tag}
        </span>
      ))}
    </div>
  </div>

  <!-- Footer: precio + CTAs -->
  <div class="border-t border-theme-border p-5 flex flex-col gap-3">
    <div class="flex items-baseline gap-1">
      <span class="text-2xl font-bold font-display text-theme-accent">{priceFormatted}</span>
      <span class="text-xs text-theme-muted">{course.currency === 'CLP' ? 'CLP / mes' : 'USD / mes'}</span>
    </div>

    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary w-full justify-center"
      aria-label={`Consultar por WhatsApp sobre ${course.title}`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
           fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
      Más información
    </a>
  </div>
</article>

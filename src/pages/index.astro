---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CoursesSection from '@/components/sections/CoursesSection.astro';
import { buildWhatsappUrl } from '@/data/courses';
import imgHero from '../assets/images/hero-guitarra.jpeg';
import imgRetrato from '../assets/images/retrato3.jpg';
import imgEnVivo from '../assets/images/en-vivo.jpeg';
import imgKofi from '../assets/images/kofi.png';

const heroWhatsapp = buildWhatsappUrl(
  'Hola Elinad 👋 Vi tu página y me gustaría saber más sobre las clases de bajo y ukelele.'
);
---

<BaseLayout>
  <!-- ====================================================
       HERO
       ==================================================== -->
  <section
    id="inicio"
    aria-label="Presentación"
    class="relative overflow-hidden py-24 md:py-36 px-4 sm:px-6 lg:px-8"
  >
    <!-- Foto de fondo -->
    <div class="absolute inset-0 -z-10" aria-hidden="true">
      <img
        src={imgHero.src}
        alt=""
        width="2764"
        height="4138"
        class="w-full h-full object-cover object-center"
        fetchpriority="high"
        decoding="async"
      />
      <!-- Overlay degradado para legibilidad del texto -->
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/60 to-black/80"></div>
    </div>

    <div class="max-w-4xl mx-auto text-center">
      <span
        class="inline-block text-xs font-semibold uppercase tracking-[0.2em]
               text-theme-accent border border-theme-accent/60 rounded-full
               px-4 py-1.5 mb-6 backdrop-blur-sm"
      >
        Bajista Profesional · Profesor de Música · Santiago, Chile
      </span>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold text-white leading-tight drop-shadow-lg">
        Aprende bajo eléctrico, ukelele y música a tu ritmo
      </h1>

      <p class="mt-6 text-lg md:text-xl text-white/80 max-w-2xl mx-auto leading-relaxed drop-shadow">
        Clases personalizadas de bajo eléctrico, ukelele, guitarra, teoría musical y más, adaptadas a tu nivel, objetivos y ritmo. Modalidad preferentemente online, con opción presencial según disponibilidad.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#cursos" class="btn-primary text-base px-7 py-4">
          Ver cursos y talleres
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
               stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </a>
        <a href={heroWhatsapp} target="_blank" rel="noopener noreferrer"
           class="btn-secondary text-base px-7 py-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
               fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          Escribir por WhatsApp
        </a>
      </div>

      <!-- Estadísticas rápidas -->
      <div class="mt-16 grid grid-cols-3 gap-6 max-w-lg mx-auto">
        {[
          { value: '+50', label: 'Alumnos' },
          { value: '4', label: 'Cursos' },
          { value: '2', label: 'Modalidades' },
        ].map(({ value, label }) => (
          <div class="text-center backdrop-blur-sm bg-white/5 rounded-2xl py-3 px-2">
            <div class="text-2xl font-display font-bold text-theme-accent">{value}</div>
            <div class="text-xs text-white/70 mt-0.5">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================================================
       CURSOS Y TALLERES
       ==================================================== -->
  <CoursesSection />

  <!-- ====================================================
       SOBRE MÍ
       ==================================================== -->
  <section
    id="sobre-mi"
    aria-labelledby="about-heading"
    class="py-20 px-4 sm:px-6 lg:px-8 bg-theme-surface/40"
  >
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- Foto de perfil -->
        <div class="relative">
          <div class="aspect-[3/4] rounded-3xl overflow-hidden shadow-2xl ring-4 ring-theme-accent/20">
            <img
              src={imgRetrato.src}
              alt="Elinad con su bajo"
              width="2069"
              height="2832"
              class="w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
            />
          </div>
          <!-- Detalle decorativo -->
          <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-theme-accent/20 rounded-full blur-2xl -z-10"></div>
          <div class="absolute -top-4 -left-4 w-16 h-16 bg-theme-accent/10 rounded-full blur-xl -z-10"></div>
        </div>

        <!-- Texto -->
        <div>
          <span class="text-theme-accent font-semibold text-sm uppercase tracking-widest">
            Quién soy
          </span>
          <h2 id="about-heading" class="section-title mt-2">
            Hola, soy Elinad Bass
          </h2>
          <div class="space-y-4 mt-5 text-theme-muted leading-relaxed">
            <p>
              Soy Profesor de Música titulado y bajista profesional con estudios en ESJAZZ.
              Cuento con más de 10 años de experiencia enseñando a estudiantes de distintas edades y niveles.
              Mi formación combina estudios universitarios de pedagogía en música y especialización en bajo eléctrico,
              además de una activa trayectoria como intérprete y tallerista.
            </p>
            <p>
              Mi enfoque une técnica, musicalidad y disfrute del aprendizaje. Ya sea que estés
              comenzando desde cero o quieras profundizar tus conocimientos, cada clase se adapta a
              tus objetivos, intereses y ritmo de avance. Creo que aprender música debe ser un
              proceso motivador, práctico y conectado con la música que realmente te inspira.
            </p>
          </div>
          <a
            href={buildWhatsappUrl('Hola Elinad 👋 Me gustaría conocer más sobre ti y tu método de enseñanza.')}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary mt-8 inline-flex"
          >
            Contáctame
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================
       TESTIMONIOS
       ==================================================== -->
  <section
    id="testimonios"
    aria-labelledby="testimonials-heading"
    class="py-20 px-4 sm:px-6 lg:px-8"
  >
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <span class="text-theme-accent font-semibold text-sm uppercase tracking-widest">
          Lo que dicen
        </span>
        <h2 id="testimonials-heading" class="section-title mt-2">
          Testimonios
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-6">
        {[
          {
            name: 'Lautaro',
            role: 'Estudiante de bajo eléctrico, 11 años.',
            quote: 'Lo que más me ha gustado es que Daniel hace las clases muy entretenidas y explica muy bien. Siempre me ayuda a mejorar y me motiva a seguir aprendiendo.',
          },
          {
            name: 'Daniela',
            role: 'Madre de Nahuel, estudiante de guitarra.',
            quote: 'Mi hijo de 8 años toma clases de guitarra con Daniel y estamos muy conformes. Tiene muy buena llegada con los niños, es paciente, responsable y cercano. Las clases se basan en canciones que a mi hijo le gustan, lo que lo motiva mucho más y le ha permitido aprender muy rápido. ¡Totalmente recomendado!',
          },
          {
            name: 'Erika',
            role: 'Estudiante del Taller de Ukelele.',
            quote: 'Aprendí desde cero y gané mucha confianza. Recomiendo las clases a cualquier persona que quiera avanzar a su propio ritmo, con un profesor que realmente se preocupa por sus estudiantes. Además, el ambiente es excelente. ¡100% recomendado!',
          },
          {
            name: 'Camila Muñoz',
            role: 'Estudiante de técnica vocal y composición.',
            quote: '¡El profe Daniel es muy seco! Me ayudó mucho con el canto y también con proyectos personales de composición. Siempre mostró mucha dedicación y adaptó las clases a mi ritmo de aprendizaje.',
          },
        ].map(({ name, role, quote }) => (
          <blockquote class="card p-6 flex flex-col gap-4">
            <p class="text-theme-muted text-sm leading-relaxed flex-1">
              "{quote}"
            </p>
            <footer>
              <cite class="not-italic">
                <span class="block font-semibold text-theme-text text-sm">{name}</span>
                <span class="block text-xs text-theme-accent">{role}</span>
              </cite>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================================================
       EN VIVO / MÚSICA EN ACCIÓN
       ==================================================== -->
  <section
    aria-label="Elinad en vivo"
    class="relative overflow-hidden py-0"
  >
    <div class="relative h-[420px] md:h-[540px]">
      <img
        src={imgEnVivo.src}
        alt="Elinad tocando en vivo con micrófono"
        width="4237"
        height="2830"
        class="w-full h-full object-cover object-center"
        loading="lazy"
        decoding="async"
      />
      <!-- Overlay -->
      <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent"></div>

      <!-- Contenido sobre la imagen -->
      <div class="absolute inset-0 flex items-center px-8 sm:px-16 lg:px-24">
        <div class="max-w-lg">
          <span class="text-theme-accent font-semibold text-sm uppercase tracking-widest">
            Más que clases
          </span>
          <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mt-2 leading-tight drop-shadow-lg">
            Mi forma de enseñar
          </h2>
          <div class="mt-4 text-white/80 leading-relaxed text-base space-y-3">
            <p>
              Al enseñar, me dedico a comprender los objetivos, intereses y formas de aprender de cada
              estudiante para favorecer un avance constante y ayudarle a desarrollar sus propias habilidades.
            </p>
            <p>
              Creo que el aprendizaje debe ir acompañado del disfrute musical, así el proceso se vuelve
              más significativo y duradero.
            </p>
            <p>
              Mi objetivo es entregarte las herramientas para desarrollar tus habilidades musicales y
              acompañarte en tu propio camino de aprendizaje.
            </p>
          </div>
          <a
            href="#cursos"
            class="mt-7 inline-flex items-center gap-2 btn-primary"
          >
            Ver cursos
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================
       CONTACTO / CTA FINAL
       ==================================================== -->
  <section
    id="contacto"
    aria-labelledby="contact-heading"
    class="py-20 px-4 sm:px-6 lg:px-8 bg-theme-surface/40"
  >
    <div class="max-w-2xl mx-auto text-center">
      <span class="text-theme-accent font-semibold text-sm uppercase tracking-widest">
        ¿Listo/a para empezar?
      </span>
      <h2 id="contact-heading" class="section-title mt-2">
        Hablemos
      </h2>
      <p class="section-subtitle mx-auto mt-4">
        Si tienes preguntas o quieres conocer la modalidad de las clases, escríbeme por WhatsApp.
        Estaré encantado de orientarte y ayudarte a encontrar la opción que mejor se adapte a tus objetivos.
      </p>
      <a
        href={buildWhatsappUrl('Hola Elinad 👋 Tengo preguntas sobre las clases. ¿Me puedes orientar?')}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary mt-10 text-base px-8 py-4 inline-flex"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        Escríbeme por WhatsApp
      </a>
      <p class="text-xs text-theme-muted mt-4">Sin compromiso · Responderé a la brevedad</p>

      <!-- Ko-fi — apoyo voluntario discreto -->
      <div class="mt-8 mx-auto max-w-xs rounded-2xl bg-theme-surface/60 border border-theme-border/40 px-5 py-4 text-center">
        <p class="text-xs text-theme-muted leading-relaxed mb-3">
          ¿Disfrutas el contenido que comparto?<br/>
          Puedes apoyar mi trabajo con un café en Ko-fi.
        </p>
        <a
          href="https://ko-fi.com/elinadbass"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full font-medium text-xs
                 bg-theme-border/50 hover:bg-theme-border text-theme-muted hover:text-theme-text
                 transition-all duration-200"
          aria-label="Apoyar a Elinad en Ko-fi"
        >
          ☕ Ko-fi
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

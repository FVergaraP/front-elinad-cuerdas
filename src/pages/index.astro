---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CoursesSection from '@/components/sections/CoursesSection.astro';
import { buildWhatsappUrl } from '@/data/courses';

const heroWhatsapp = buildWhatsappUrl(
  'Hola Elinad 👋 Vi tu página y me gustaría saber más sobre las clases de guitarra.'
);
---

<BaseLayout>
  <!-- ====================================================
       HERO
       ==================================================== -->
  <section
    id="inicio"
    aria-label="Presentación"
    class="relative overflow-hidden py-24 md:py-36 px-4 sm:px-6 lg:px-8"
  >
    <!-- Fondo decorativo -->
    <div
      class="absolute inset-0 -z-10 pointer-events-none"
      aria-hidden="true"
    >
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px]
               bg-theme-accent/10 blur-[100px] rounded-full"
      ></div>
    </div>

    <div class="max-w-4xl mx-auto text-center">
      <span
        class="inline-block text-xs font-semibold uppercase tracking-[0.2em]
               text-theme-accent border border-theme-accent/40 rounded-full
               px-4 py-1.5 mb-6"
      >
        Clases de Guitarra · Santiago, Chile
      </span>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold text-theme-text leading-tight">
        Aprende guitarra
        <span class="text-theme-accent block sm:inline"> con pasión</span>
      </h1>

      <p class="mt-6 text-lg md:text-xl text-theme-muted max-w-2xl mx-auto leading-relaxed">
        Cursos personalizados, talleres grupales y clases para todos los niveles.
        Presencial, online o híbrido — tú eliges el camino, yo te acompaño.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#cursos" class="btn-primary text-base px-7 py-4">
          Ver cursos disponibles
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
               stroke-linejoin="round" aria-hidden="true">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </a>
        <a href={heroWhatsapp} target="_blank" rel="noopener noreferrer"
           class="btn-secondary text-base px-7 py-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
               fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
          Escribir por WhatsApp
        </a>
      </div>

      <!-- Estadísticas rápidas -->
      <div class="mt-16 grid grid-cols-3 gap-6 max-w-lg mx-auto">
        {[
          { value: '+50', label: 'Alumnos' },
          { value: '5', label: 'Cursos' },
          { value: '3', label: 'Modalidades' },
        ].map(({ value, label }) => (
          <div class="text-center">
            <div class="text-2xl font-display font-bold text-theme-accent">{value}</div>
            <div class="text-xs text-theme-muted mt-0.5">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================================================
       CURSOS Y TALLERES
       ==================================================== -->
  <CoursesSection />

  <!-- ====================================================
       SOBRE MÍ
       ==================================================== -->
  <section
    id="sobre-mi"
    aria-labelledby="about-heading"
    class="py-20 px-4 sm:px-6 lg:px-8 bg-theme-surface/40"
  >
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- Foto placeholder -->
        <div
          class="aspect-square rounded-3xl bg-theme-surface border-2 border-theme-border
                 flex items-center justify-center text-8xl"
          aria-hidden="true"
        >
          🎸
        </div>

        <!-- Texto -->
        <div>
          <span class="text-theme-accent font-semibold text-sm uppercase tracking-widest">
            Quién soy
          </span>
          <h2 id="about-heading" class="section-title mt-2">
            Hola, soy Elinad
          </h2>
          <div class="space-y-4 mt-5 text-theme-muted leading-relaxed">
            <p>
              Soy profesora de guitarra con más de 10 años de experiencia enseñando a personas
              de todas las edades y niveles. Mi enfoque combina técnica sólida con música
              que genuinamente te gusta tocar.
            </p>
            <p>
              Creo en el aprendizaje progresivo y en que cada alumno tiene su propio ritmo.
              No importa si nunca has tocado un instrumento o si llevas años y quieres
              perfeccionar tu técnica — encontramos el camino juntos.
            </p>
          </div>
          <a
            href={buildWhatsappUrl('Hola Elinad 👋 Me gustaría conocer más sobre ti y tu método de enseñanza.')}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary mt-8 inline-flex"
          >
            Contáctame
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================
       TESTIMONIOS
       ==================================================== -->
  <section
    id="testimonios"
    aria-labelledby="testimonials-heading"
    class="py-20 px-4 sm:px-6 lg:px-8"
  >
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <span class="text-theme-accent font-semibold text-sm uppercase tracking-widest">
          Lo que dicen
        </span>
        <h2 id="testimonials-heading" class="section-title mt-2">
          Testimonios
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            name: 'María J.',
            role: 'Alumna — Curso Iniciación',
            quote: 'Llegué sin saber nada de guitarra y en 2 meses ya tocaba mis canciones favoritas. La paciencia y claridad de Elinad hacen toda la diferencia.',
          },
          {
            name: 'Tomás R.',
            role: 'Alumno — Guitarra Intermedia',
            quote: 'El nivel de detalle en cada clase es impresionante. Aprendí más teoría musical en este curso que en años de tocar solo.',
          },
          {
            name: 'Valentina M.',
            role: 'Alumna — Taller Eléctrica',
            quote: 'Siempre quise aprender rock y por fin lo hice. El taller es intenso pero muy entretenido. ¡Totalmente recomendado!',
          },
        ].map(({ name, role, quote }) => (
          <blockquote class="card p-6 flex flex-col gap-4">
            <p class="text-theme-muted text-sm leading-relaxed flex-1">
              "{quote}"
            </p>
            <footer>
              <cite class="not-italic">
                <span class="block font-semibold text-theme-text text-sm">{name}</span>
                <span class="block text-xs text-theme-accent">{role}</span>
              </cite>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================================================
       CONTACTO / CTA FINAL
       ==================================================== -->
  <section
    id="contacto"
    aria-labelledby="contact-heading"
    class="py-20 px-4 sm:px-6 lg:px-8 bg-theme-surface/40"
  >
    <div class="max-w-2xl mx-auto text-center">
      <span class="text-theme-accent font-semibold text-sm uppercase tracking-widest">
        ¿Listo/a para empezar?
      </span>
      <h2 id="contact-heading" class="section-title mt-2">
        Hablemos
      </h2>
      <p class="section-subtitle mx-auto mt-4">
        Escríbeme por WhatsApp y respondemos a la brevedad para coordinar tu primera clase
        de prueba sin costo.
      </p>
      <a
        href={buildWhatsappUrl('Hola Elinad 👋 Me gustaría agendar una clase de prueba. ¿Cuándo tienes disponibilidad?')}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary mt-10 text-base px-8 py-4 inline-flex"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        Agendar clase de prueba gratis
      </a>
      <p class="text-xs text-theme-muted mt-4">Sin compromiso · Respuesta en menos de 1 hora</p>
    </div>
  </section>
</BaseLayout>

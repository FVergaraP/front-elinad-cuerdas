---
import '@/styles/global.css';
import ThemeSwitcher from '@/components/ui/ThemeSwitcher.astro';
import FontSwitcher from '@/components/ui/FontSwitcher.astro';
import { DEFAULT_THEME, THEME_STORAGE_KEY } from '@/lib/themes';
import { DEFAULT_FONT, FONT_STORAGE_KEY } from '@/lib/fonts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Elinad Cuerdas — Clases y Talleres de Bajo y Ukelele',
  description = 'Aprende bajo y ukelele con Elinad: cursos personalizados, talleres grupales y clases para todos los niveles en Santiago de Chile.',
  image = '/og-image.jpg',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es" data-theme={DEFAULT_THEME} data-font={DEFAULT_FONT}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content="Elinad Cuerdas" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Schema.org: Profesora de bajo y ukelele / Negocio local -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "@id": `${Astro.site}#person`,
          "name": "Elinad",
          "jobTitle": "Profesora de Bajo y Ukelele",
          "description": "Profesora de bajo y ukelele con más de 10 años de experiencia en Santiago de Chile. Clases personalizadas, talleres grupales y modalidad online.",
          "url": String(Astro.site),
          "sameAs": [
            "https://www.instagram.com/elinadbass/",
            "https://www.tiktok.com/@elinad.bass"
          ]
        },
        {
          "@type": "LocalBusiness",
          "@id": `${Astro.site}#business`,
          "name": "Elinad Cuerdas",
          "description": "Clases y talleres de bajo y ukelele en Santiago de Chile. Presencial, online o híbrido para todos los niveles.",
          "url": String(Astro.site),
          "telephone": "+56965017566",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Santiago",
            "addressRegion": "Región Metropolitana",
            "addressCountry": "CL"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": -33.4489,
            "longitude": -70.6693
          },
          "priceRange": "$$",
          "currenciesAccepted": "CLP",
          "paymentAccepted": "Transferencia bancaria, efectivo",
          "openingHours": "Mo-Sa 09:00-21:00",
          "sameAs": [
            "https://www.instagram.com/elinadbass/",
            "https://www.tiktok.com/@elinad.bass"
          ],
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Cursos de bajo y ukelele",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Clases de bajo eléctrico para principiantes" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Clases de bajo intermedio" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Taller de ukelele" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Clases de bajo y ukelele online" } }
            ]
          }
        }
      ]
    })} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Todas las fuentes cargadas de una vez para que el cambio sea instantáneo -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&family=Lato:wght@400;700&family=Playfair+Display:wght@700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Aplicar tema Y fuente guardados ANTES de pintar (evita flash) -->
    <script is:inline define:vars={{ THEME_STORAGE_KEY, DEFAULT_THEME, FONT_STORAGE_KEY, DEFAULT_FONT }}>
      (function () {
        const theme = localStorage.getItem(THEME_STORAGE_KEY) ?? DEFAULT_THEME;
        const font  = localStorage.getItem(FONT_STORAGE_KEY)  ?? DEFAULT_FONT;
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.setAttribute('data-font', font);
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- ===== HEADER / NAVBAR ===== -->
    <header
      id="site-header"
      class="sticky top-0 z-40 w-full border-b border-theme-border/60
             bg-theme-bg/80 backdrop-blur-md"
    >
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
        <!-- Logo / Nombre -->
        <a href="/" class="flex items-center gap-2.5 group" aria-label="Inicio — Elinad Cuerdas">
          <span
            class="text-2xl leading-none select-none group-hover:scale-110 transition-transform"
            aria-hidden="true"
          >🎸</span>
          <span class="font-display font-bold text-lg text-theme-text group-hover:text-theme-accent transition-colors">
            Elinad Cuerdas
          </span>
        </a>

        <!-- Navegación desktop -->
        <nav class="hidden md:flex items-center gap-6" aria-label="Navegación principal">
          <a href="#cursos"       class="text-sm text-theme-muted hover:text-theme-text transition-colors">Cursos</a>
          <a href="#sobre-mi"    class="text-sm text-theme-muted hover:text-theme-text transition-colors">Sobre mí</a>
          <a href="#testimonios" class="text-sm text-theme-muted hover:text-theme-text transition-colors">Testimonios</a>
          <a href="#contacto"    class="text-sm text-theme-muted hover:text-theme-text transition-colors">Contacto</a>
        </nav>

        <!-- Acciones -->
        <div class="flex items-center gap-2">
          <ThemeSwitcher />
          <FontSwitcher />

          <!-- Redes sociales -->
          <a
            href="https://www.instagram.com/elinadbass/"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden sm:flex p-2 rounded-lg text-theme-muted hover:text-theme-accent hover:bg-theme-surface transition-colors"
            aria-label="Instagram de Elinad"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href="https://www.tiktok.com/@elinad.bass"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden sm:flex p-2 rounded-lg text-theme-muted hover:text-theme-accent hover:bg-theme-surface transition-colors"
            aria-label="TikTok de Elinad"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
            </svg>
          </a>

          <!-- CTA WhatsApp -->
          <a
            href={`https://wa.me/56965017566?text=${encodeURIComponent('Hola Elinad 👋 Quisiera saber más sobre tus clases de bajo y ukelele.')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary hidden sm:inline-flex text-xs px-4 py-2"
            aria-label="Contactar por WhatsApp"
          >
            Escríbeme
          </a>

          <!-- Hamburger mobile -->
          <button
            id="mobile-menu-toggle"
            class="md:hidden p-2 rounded-lg text-theme-muted hover:text-theme-text
                   hover:bg-theme-surface transition-colors"
            aria-label="Abrir menú"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 viewBox="0 0 24 24" aria-hidden="true">
              <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
            <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 viewBox="0 0 24 24" class="hidden" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Menú mobile -->
      <div
        id="mobile-menu"
        class="hidden md:hidden border-t border-theme-border bg-theme-bg/95 backdrop-blur-md"
        aria-label="Menú móvil"
      >
        <nav class="flex flex-col px-4 py-4 gap-1">
          <a href="#cursos"       class="py-2.5 text-sm text-theme-muted hover:text-theme-accent transition-colors">Cursos</a>
          <a href="#sobre-mi"    class="py-2.5 text-sm text-theme-muted hover:text-theme-accent transition-colors">Sobre mí</a>
          <a href="#testimonios" class="py-2.5 text-sm text-theme-muted hover:text-theme-accent transition-colors">Testimonios</a>
          <a href="#contacto"    class="py-2.5 text-sm text-theme-muted hover:text-theme-accent transition-colors">Contacto</a>
          <a
            href={`https://wa.me/56965017566?text=${encodeURIComponent('Hola Elinad 👋 Quisiera saber más sobre tus clases de bajo y ukelele.')}`}
            target="_blank" rel="noopener noreferrer"
            class="btn-primary mt-2 justify-center text-xs"
          >
            Escríbeme por WhatsApp
          </a>
          <!-- Redes sociales mobile -->
          <div class="flex items-center gap-4 pt-3 border-t border-theme-border mt-1">
            <a
              href="https://www.instagram.com/elinadbass/"
              target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm text-theme-muted hover:text-theme-accent transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              Instagram
            </a>
            <a
              href="https://www.tiktok.com/@elinad.bass"
              target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm text-theme-muted hover:text-theme-accent transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
              </svg>
              TikTok
            </a>
          </div>
        </nav>
      </div>
    </header>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="border-t border-theme-border mt-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="text-center md:text-left">
            <span class="font-display font-bold text-theme-text">Elinad Cuerdas</span>
            <p class="text-xs text-theme-muted mt-1">
              Clases y talleres de bajo y ukelele · Santiago, Chile
            </p>
          </div>
          <div class="flex items-center gap-5 text-xs text-theme-muted">
            <a href="#cursos"   class="hover:text-theme-accent transition-colors">Cursos</a>
            <a href="#contacto" class="hover:text-theme-accent transition-colors">Contacto</a>
            <a
              href="https://wa.me/56965017566"
              target="_blank" rel="noopener noreferrer"
              class="hover:text-theme-accent transition-colors"
            >WhatsApp</a>
            <a
              href="https://www.instagram.com/elinadbass/"
              target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-1.5 hover:text-theme-accent transition-colors"
              aria-label="Instagram"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              Instagram
            </a>
            <a
              href="https://www.tiktok.com/@elinad.bass"
              target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-1.5 hover:text-theme-accent transition-colors"
              aria-label="TikTok"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
              </svg>
              TikTok
            </a>
          </div>
          <p class="text-xs text-theme-muted text-center">
            © {new Date().getFullYear()} Elinad Cuerdas. Todos los derechos reservados.
          </p>
        </div>
      </div>
    </footer>

    <!-- Mobile menu script -->
    <script>
      const toggle   = document.getElementById('mobile-menu-toggle');
      const menu     = document.getElementById('mobile-menu');
      const iconOpen  = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');

      toggle?.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isOpen));
        menu?.classList.toggle('hidden', isOpen);
        iconOpen?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
      });

      menu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          toggle?.setAttribute('aria-expanded', 'false');
          menu.classList.add('hidden');
          iconOpen?.classList.remove('hidden');
          iconClose?.classList.add('hidden');
        });
      });
    </script>
  </body>
</html>
